<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : 'Print' %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
      @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap');

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'DM Sans', sans-serif;
        background: #f8f9fa;
        color: #212529;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: flex-start;
        padding: 24px 16px 48px;
        -webkit-font-smoothing: antialiased;
      }

      /* Screen-only toolbar */
      .print-toolbar {
        width: 100%;
        max-width: 480px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
      }

      .print-toolbar a {
        font-size: 14px;
        font-weight: 600;
        color: #6c757d;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 6px;
      }
      .print-toolbar a:hover { color: #212529; }

      .print-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: #ff3b5c;
        color: white;
        font-family: 'Syne', sans-serif;
        font-size: 14px;
        font-weight: 700;
        padding: 9px 18px;
        border: none;
        border-radius: 9px;
        cursor: pointer;
        text-decoration: none;
        transition: background 0.15s;
      }
      .print-btn:hover { background: #e82e4f; color: white; }

      /* The printable card */
      .qr-card {
        width: 100%;
        max-width: 480px;
        background: white;
        border-radius: 20px;
        border: 1px solid #dee2e6;
        overflow: hidden;
        box-shadow: 0 2px 16px rgba(0,0,0,0.06);
      }

      .qr-card__header {
        background: linear-gradient(135deg, #ff3b5c 0%, #c01133 100%);
        padding: 28px 28px 24px;
        text-align: center;
        color: white;
      }

      .qr-card__vendor-name {
        font-family: 'Syne', sans-serif;
        font-size: 28px;
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 6px;
        letter-spacing: -0.02em;
      }

      .qr-card__hook {
        font-size: 15px;
        font-weight: 500;
        opacity: 0.9;
        line-height: 1.4;
      }

      .qr-card__body {
        padding: 28px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
      }

      .qr-card__cta {
        font-size: 16px;
        font-weight: 600;
        color: #495057;
        text-align: center;
        line-height: 1.4;
      }

      .qr-card__cta strong {
        display: block;
        font-family: 'Syne', sans-serif;
        font-size: 21px;
        font-weight: 800;
        color: #212529;
        margin-bottom: 4px;
      }

      .qr-card__qr {
        width: 240px;
        height: 240px;
        border: 3px solid #f1f3f5;
        border-radius: 12px;
        padding: 8px;
        background: white;
      }

      .qr-card__url {
        font-size: 11px;
        color: #adb5bd;
        text-align: center;
        word-break: break-all;
        max-width: 280px;
      }

      .qr-card__booth {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 10px;
        padding: 12px 20px;
        text-align: center;
        width: 100%;
      }

      .qr-card__booth-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #adb5bd;
        margin-bottom: 3px;
      }

      .qr-card__booth-value {
        font-family: 'Syne', sans-serif;
        font-size: 22px;
        font-weight: 800;
        color: #212529;
      }

      .qr-card__event {
        font-size: 12px;
        color: #adb5bd;
        text-align: center;
        padding-bottom: 4px;
      }

      /* Print styles */
      @media print {
        body {
          background: white;
          padding: 0;
          justify-content: center;
        }

        .print-toolbar { display: none; }

        .qr-card {
          max-width: 100%;
          border: none;
          border-radius: 0;
          box-shadow: none;
          page-break-inside: avoid;
        }

        .qr-card__header {
          -webkit-print-color-adjust: exact;
          print-color-adjust: exact;
        }
      }
    </style>
  </head>
  <body>
    <%= yield %>
  </body>
</html>
