<% content_for :title, @vendor_event.event.name %>
<% content_for :back_link do %>
  <%= link_to vendor_vendor_path(@vendor), class: 'vd-back' do %>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="15 18 9 12 15 6"/>
    </svg>
  <% end %>
<% end %>

<%# ── Stats strip ── %>
<div style="padding-top: 16px; margin-bottom: 24px;">
  <p style="font-size:13px; color:#6c757d; margin-bottom:12px;">
    <%= @vendor_event.event.event_date.strftime('%B %-d, %Y') %>
    <% booth = @vendor_event.metadata&.dig('booth_number') %>
    <% hall  = @vendor_event.metadata&.dig('hall') %>
    <%= " · Booth #{booth}" if booth.present? %>
    <%= ", #{hall}"         if hall.present? %>
  </p>

  <div class="vd-stats">
    <div class="vd-stat">
      <div class="vd-stat__num"><%= @vendor_event.opt_in_count %></div>
      <div class="vd-stat__label">Opt-ins</div>
      <% if @vendor_event.opt_in_count > 0 %>
        <div style="font-size:10px; color:#adb5bd; margin-top:5px; line-height:1.6;">
          📱&nbsp;<%= @phone_count %>&nbsp;·&nbsp;✉️&nbsp;<%= @email_count %>
        </div>
      <% end %>
    </div>
    <div class="vd-stat">
      <div class="vd-stat__num"><%= @vendor_event.broadcasts.sent.count %></div>
      <div class="vd-stat__label">Sent</div>
    </div>
    <div class="vd-stat">
      <div class="vd-stat__num">
        <%= @vendor_event.event.con_opt_ins.count %>
      </div>
      <div class="vd-stat__label">Con total</div>
    </div>
  </div>
</div>

<%# ── Opt-in timeline ── %>
<% if @opt_in_timeline.any? %>
  <p class="vd-section-label">Opt-in Timeline</p>
  <div class="vd-card" style="margin-bottom: 24px;">
    <div class="vd-card__body" style="overflow-x: auto; padding-bottom: 14px;">
      <% tl_max = @opt_in_timeline.values.max.to_f %>
      <% tl_min_width = [@opt_in_timeline.size * 34, 240].max %>
      <div style="display:flex; align-items:flex-end; gap:6px; height:72px; min-width:<%= tl_min_width %>px;">
        <% @opt_in_timeline.each do |hour, count| %>
          <div style="flex:1; min-width:28px; display:flex; flex-direction:column; align-items:center; gap:3px;">
            <div style="font-size:9px; color:#6c757d; font-weight:600; min-height:12px;">
              <%= count %>
            </div>
            <div style="width:100%; background:#a78bfa; border-radius:3px 3px 0 0;
                        height:<%= [(count / tl_max * 48).round, 4].max %>px;"></div>
          </div>
        <% end %>
      </div>
      <div style="display:flex; gap:6px; margin-top:5px; min-width:<%= tl_min_width %>px;">
        <% @opt_in_timeline.each do |hour, _| %>
          <div style="flex:1; min-width:28px; font-size:9px; color:#adb5bd;
                      text-align:center; overflow:hidden; white-space:nowrap;">
            <%= hour.strftime('%-I%p').downcase %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>

<%# ── Onboarding checklist ── %>
<% booth_set      = @vendor_event.booth_number.present?
   load_in_set    = @vendor_event.metadata&.dig('load_in_date').present? ||
                    @vendor_event.metadata&.dig('load_in_notes').present?
   profile_set    = @vendor_event.vendor.hook_line.present? && @vendor_event.vendor.description.present?
   social_set     = @vendor_event.vendor.social_handles.any? || @vendor_event.vendor.website.present?
   all_done       = booth_set && load_in_set && profile_set && social_set
%>
<% unless all_done %>
<p class="vd-section-label">Setup Checklist</p>
<div class="vd-card" style="margin-bottom: 24px;">
  <div class="vd-card__body" style="padding: 0;">
    <% checklist = [
         { done: booth_set,   label: 'Booth location confirmed',   sub: 'Add booth # and hall',       url: edit_vendor_vendor_event_path(@vendor_event) },
         { done: load_in_set, label: 'Load-in info set',           sub: 'Date, time window, notes',   url: edit_vendor_vendor_event_path(@vendor_event) },
         { done: profile_set, label: 'Vendor profile complete',    sub: 'Hook line + description',    url: edit_vendor_vendor_path(@vendor_event.vendor) },
         { done: social_set,  label: 'Website or social link set', sub: 'Helps attendees find you',   url: edit_vendor_vendor_path(@vendor_event.vendor) },
       ] %>
    <% checklist.each_with_index do |item, i| %>
      <div style="display:flex; align-items:center; gap:12px; padding:14px 16px;
                  <%= i < checklist.length - 1 ? 'border-bottom:1px solid #e9ecef;' : '' %>">
        <span style="font-size:18px; flex-shrink:0;"><%= item[:done] ? '✅' : '⬜' %></span>
        <div style="flex:1; min-width:0;">
          <div style="font-size:14px; font-weight:600; <%= item[:done] ? 'color:#adb5bd;' : '' %>">
            <%= item[:label] %>
          </div>
          <% unless item[:done] %>
            <div style="font-size:12px; color:#6c757d; margin-top:2px;"><%= item[:sub] %></div>
          <% end %>
        </div>
        <% unless item[:done] %>
          <%= link_to 'Fix →', item[:url],
                      style: 'font-size:12px; color:#7c3aed; text-decoration:none; flex-shrink:0;' %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
<% end %>

<%# ── Logistics card ── %>
<p class="vd-section-label">
  Logistics
  <%= link_to 'Edit', edit_vendor_vendor_event_path(@vendor_event),
              style: 'font-size:12px; color:#7c3aed; text-decoration:none; margin-left:8px;' %>
</p>
<div class="vd-card" style="margin-bottom: 24px;">
  <div class="vd-card__body">
    <% booth  = @vendor_event.booth_number
       hall   = @vendor_event.hall
       li_date  = @vendor_event.metadata&.dig('load_in_date')
       li_time  = @vendor_event.metadata&.dig('load_in_time')
       li_notes = @vendor_event.metadata&.dig('load_in_notes')
    %>
    <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin-bottom: <%= (li_date || li_time || li_notes) ? '16px' : '0' %>;">
      <div>
        <div style="font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:#adb5bd; margin-bottom:4px;">Booth</div>
        <div style="font-size:16px; font-weight:700;"><%= booth.present? ? booth : '—' %></div>
      </div>
      <div>
        <div style="font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:#adb5bd; margin-bottom:4px;">Hall / Section</div>
        <div style="font-size:16px; font-weight:700;"><%= hall.present? ? hall : '—' %></div>
      </div>
    </div>
    <% if li_date || li_time || li_notes %>
      <div style="border-top:1px solid #e9ecef; padding-top:14px;">
        <div style="font-size:11px; text-transform:uppercase; letter-spacing:0.08em; color:#adb5bd; margin-bottom:8px;">Load-in</div>
        <% if li_date || li_time %>
          <div style="font-size:14px; font-weight:600; margin-bottom:4px;">
            <%= [li_date, li_time].compact.join(' · ') %>
          </div>
        <% end %>
        <% if li_notes %>
          <div style="font-size:13px; color:#495057; line-height:1.5;"><%= li_notes %></div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<%# ── Broadcast form ── %>
<p class="vd-section-label">Send a Broadcast</p>
<div class="vd-card" style="margin-bottom: 24px;">
  <div class="vd-card__body">
    <%= form_with model: @new_broadcast,
                  url: broadcast_vendor_vendor_event_path(@vendor_event),
                  class: 'vd-broadcast-form',
                  data: { controller: 'broadcast-form' } do |f| %>

      <%# Scope toggle — who receives this? %>
      <div class="vd-field">
        <span class="vd-label">Send to</span>
        <div class="vd-scope-toggle">
          <div class="vd-scope-option">
            <%= f.radio_button :scope, 'booth_visitors', checked: true %>
            <label class="vd-scope-label" for="broadcast_scope_booth_visitors">
              <span class="vd-scope-label__icon">🎯</span>
              <span class="vd-scope-label__text">My visitors</span>
              <span class="vd-scope-label__sub">
                <%= @vendor_event.opt_in_count %> people
              </span>
            </label>
          </div>
          <div class="vd-scope-option">
            <%= f.radio_button :scope, 'entire_con' %>
            <label class="vd-scope-label" for="broadcast_scope_entire_con">
              <span class="vd-scope-label__icon">📡</span>
              <span class="vd-scope-label__text">Whole con</span>
              <span class="vd-scope-label__sub">
                <%= @vendor_event.event.con_opt_ins.count %> people
              </span>
            </label>
          </div>
        </div>
      </div>

      <%= f.hidden_field :channel, value: 'sms' %>

      <div class="vd-field">
        <span class="vd-label">Message</span>
        <%= f.text_area :message,
                        placeholder: "Drawing at our booth in 15 min! Booth #{@vendor_event.metadata&.dig('booth_number') || '—'}",
                        class: "vd-textarea #{'is-invalid' if @new_broadcast.errors[:message].any?}",
                        rows: 3,
                        maxlength: 160,
                        data: { action: 'input->broadcast-form#countChars' } %>
        <% if @new_broadcast.errors[:message].any? %>
          <span class="vd-field-error"><%= @new_broadcast.errors[:message].first %></span>
        <% end %>
        <div class="vd-char-counter" data-broadcast-form-target="counter">
          0 / 160
        </div>
      </div>

      <%= f.submit 'Send Now',
                   class: 'vd-btn vd-btn--full',
                   data: { disable_with: 'Sending...' } %>

    <% end %>
  </div>
</div>

<%# ── QR Code ── %>
<p class="vd-section-label">Your QR Code</p>
<div class="vd-card" style="margin-bottom: 24px;">
  <div class="vd-card__body">
    <div class="vd-qr-block">
      <%# QR code image — generated via RQRCode gem or inline JS %>
      <%
        optin_url = vendor_optin_url(@vendor_event.qr_token, host: request.base_url)
      %>
      <img class="vd-qr-block__image"
           src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=<%= CGI.escape(optin_url) %>"
           alt="QR Code for <%= @vendor.name %>">
      <div class="vd-qr-block__url"><%= optin_url %></div>
    </div>
    <div style="margin-top: 14px; display: flex; gap: 8px;">
      <%= link_to qr_code_vendor_vendor_event_path(@vendor_event),
                  class: 'vd-btn vd-btn--ghost vd-btn--sm vd-btn--full',
                  target: '_blank' do %>
        Open full-size QR
      <% end %>
    </div>
  </div>
</div>

<%# ── Recent broadcasts ── %>
<% if @recent_broadcasts.any? %>
  <p class="vd-section-label">Recent Broadcasts</p>
  <div class="vd-card">
    <% @recent_broadcasts.each do |broadcast| %>
      <div class="vd-broadcast-item">
        <div class="vd-broadcast-item__message"><%= broadcast.message %></div>
        <div class="vd-broadcast-item__meta">
          <span><%= broadcast.sent_at.strftime('%-I:%M %p') %></span>
          <span><%= broadcast.recipient_count %> recipients</span>
          <span class="vd-broadcast-item__scope">
            <%= broadcast.entire_con? ? 'Whole con' : 'My visitors' %>
          </span>
          <% delivered = broadcast.broadcast_receipts.select(&:delivered?).size %>
          <% failed    = broadcast.broadcast_receipts.select(&:failed?).size %>
          <% if broadcast.recipient_count.to_i > 0 %>
            <span style="<%= failed > 0 ? 'color:#ff7a92;' : '' %>">
              <%= delivered %>/<%= broadcast.recipient_count %> delivered<%= failed > 0 ? " · #{failed} failed" : '' %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<%# ── Minimal Stimulus controller for char count ── %>
<script>
  // Simple inline char counter — no Stimulus needed
  document.addEventListener('DOMContentLoaded', function() {
    const textarea = document.querySelector('[maxlength="160"]');
    const counter  = document.querySelector('.vd-char-counter');
    if (!textarea || !counter) return;

    function update() {
      const len = textarea.value.length;
      counter.textContent = len + ' / 160';
      counter.classList.toggle('warning', len > 120);
      counter.classList.toggle('danger',  len > 150);
    }

    textarea.addEventListener('input', update);
    update();
  });
</script>
