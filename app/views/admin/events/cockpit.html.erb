<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h2 class="mb-0">Event-Day Cockpit</h2>
    <small class="text-muted"><%= @event.name %> &middot; <%= @event.display_date_range %></small>
  </div>
  <div class="d-flex gap-2">
    <%= link_to "Check-in Dashboard", checkin_dashboard_admin_event_path(@event), class: "btn btn-outline-success btn-sm" %>
    <%= link_to "Event", admin_event_path(@event), class: "btn btn-outline-secondary btn-sm" %>
  </div>
</div>

<%# ── Stats strip ── %>
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card text-center border-success">
      <div class="card-body py-3">
        <h2 class="text-success mb-0"><%= @checked_in_count %></h2>
        <small class="text-muted">Checked In</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-center border-primary">
      <div class="card-body py-3">
        <h2 class="text-primary mb-0"><%= @total_rsvped %></h2>
        <small class="text-muted">Total RSVP'd</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-center border-danger">
      <div class="card-body py-3">
        <h2 class="text-danger mb-0"><%= @vendor_events.count %></h2>
        <small class="text-muted">Vendors</small>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-center border-warning">
      <div class="card-body py-3">
        <h2 class="text-warning mb-0"><%= @recent_broadcasts.count %></h2>
        <small class="text-muted">Broadcasts Sent</small>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <%# ── Booth Leaderboard (11.5 + 11.7) ── %>
  <div class="col-md-5">
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Booth Leaderboard</h6>
        <%= link_to "All Vendors", admin_vendors_path, class: "btn btn-outline-secondary btn-sm" %>
      </div>
      <% if @vendor_events.any? %>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th class="text-center" style="width:32px;">#</th>
                <th>Vendor</th>
                <th class="text-center">Opt-ins</th>
                <th class="text-center">Broadcasts</th>
              </tr>
            </thead>
            <tbody>
              <% @vendor_events.each_with_index do |ve, i| %>
                <%
                  all_receipts = ve.broadcasts.flat_map(&:broadcast_receipts)
                  delivered    = all_receipts.count(&:delivered?)
                  total        = all_receipts.size
                  rate         = total > 0 ? (delivered * 100.0 / total).round : nil
                %>
                <tr>
                  <td class="text-center text-muted fw-semibold"><%= i + 1 %></td>
                  <td>
                    <div class="fw-semibold"><%= ve.vendor.name %></div>
                    <small class="text-muted"><%= ve.category_label %></small>
                    <% if ve.booth_number.present? %>
                      <small class="text-muted"> &middot; <%= ve.booth_number %><%= " #{ve.hall}" if ve.hall.present? %></small>
                    <% end %>
                  </td>
                  <td class="text-center fw-semibold"><%= ve.opt_in_count %></td>
                  <td class="text-center">
                    <% sent_count = ve.broadcasts.count(&:sent_at) %>
                    <% if sent_count > 0 %>
                      <div><%= sent_count %> sent</div>
                      <% if rate %>
                        <small class="<%= rate >= 90 ? 'text-success' : rate >= 70 ? 'text-warning' : 'text-danger' %>">
                          <%= rate %>% delivered
                        </small>
                      <% end %>
                    <% else %>
                      <small class="text-muted">—</small>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="card-body text-center text-muted py-4">No vendors registered for this event.</div>
      <% end %>
    </div>
  </div>

  <%# ── Recent check-ins ── %>
  <div class="col-md-4">
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0">Recent Check-ins</h6>
        <%= link_to "Full Dashboard", checkin_dashboard_admin_event_path(@event), class: "btn btn-outline-success btn-sm" %>
      </div>
      <% if @recent_checkins.any? %>
        <ul class="list-group list-group-flush">
          <% @recent_checkins.each do |p| %>
            <li class="list-group-item d-flex justify-content-between align-items-center py-2">
              <div>
                <div class="fw-semibold small"><%= p.display_name %></div>
              </div>
              <small class="text-muted"><%= p.checked_in_at.strftime('%-I:%M %p') %></small>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-center text-muted py-4">No check-ins yet.</div>
      <% end %>
    </div>
  </div>

  <%# ── Broadcast log ── %>
  <div class="col-md-3">
    <div class="card mb-4">
      <div class="card-header">
        <h6 class="mb-0">Broadcast Log</h6>
      </div>
      <% if @recent_broadcasts.any? %>
        <ul class="list-group list-group-flush">
          <% @recent_broadcasts.each do |b| %>
            <li class="list-group-item py-2">
              <div class="d-flex justify-content-between mb-1">
                <small class="fw-semibold"><%= b.vendor_event.vendor.name %></small>
                <small class="text-muted"><%= b.sent_at.strftime('%-I:%M %p') %></small>
              </div>
              <div class="small text-truncate text-muted" title="<%= b.message %>"><%= b.message %></div>
              <small class="text-muted"><%= b.recipient_count %> recipients &middot; <%= b.entire_con? ? 'Whole con' : 'Booth visitors' %></small>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="card-body text-center text-muted py-4">No broadcasts yet.</div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Event-wide opt-in heatmap (11.6) ── %>
<% if @event_opt_in_timeline.any? %>
  <div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h6 class="mb-0">Floor Traffic — Opt-in Timeline (All Vendors)</h6>
      <small class="text-muted"><%= @event_opt_in_timeline.values.sum %> total opt-ins</small>
    </div>
    <div class="card-body" style="overflow-x: auto; padding-bottom: 14px;">
      <% tl_max = @event_opt_in_timeline.values.max.to_f %>
      <% tl_min_width = [@event_opt_in_timeline.size * 34, 300].max %>
      <div style="display:flex; align-items:flex-end; gap:6px; height:80px; min-width:<%= tl_min_width %>px;">
        <% @event_opt_in_timeline.each do |hour, count| %>
          <div style="flex:1; min-width:28px; display:flex; flex-direction:column; align-items:center; gap:3px;">
            <div style="font-size:9px; color:#6c757d; font-weight:600; min-height:12px;">
              <%= count %>
            </div>
            <div style="width:100%; background:#6ea8fe; border-radius:3px 3px 0 0;
                        height:<%= [(count / tl_max * 56).round, 4].max %>px;"></div>
          </div>
        <% end %>
      </div>
      <div style="display:flex; gap:6px; margin-top:5px; min-width:<%= tl_min_width %>px;">
        <% @event_opt_in_timeline.each do |hour, _| %>
          <div style="flex:1; min-width:28px; font-size:9px; color:#adb5bd;
                      text-align:center; overflow:hidden; white-space:nowrap;">
            <%= hour.strftime('%-I%p').downcase %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
