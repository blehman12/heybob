<div class="d-flex align-items-center justify-content-between mb-4">
  <h4 class="mb-0"><i class="bi bi-trophy"></i> Sponsors</h4>
</div>

<% if @sponsors.any? %>
  <%# Group by tier %>
  <% Sponsor.tiers.keys.each do |tier_key| %>
    <% tier_sponsors = @sponsors.select { |s| s.tier == tier_key } %>
    <% next if tier_sponsors.empty? %>

    <div class="mb-5">
      <h5 class="mb-3 d-flex align-items-center gap-2">
        <span class="badge <%= Sponsor.new(tier: tier_key).tier_badge_class %> fs-6">
          <%= tier_key.capitalize %>
        </span>
        <span class="text-muted fw-normal fs-6">Sponsors</span>
      </h5>

      <div class="row row-cols-2 row-cols-md-<%= tier_key == 'title' ? '2' : tier_key == 'presenting' ? '3' : '4' %> g-4">
        <% tier_sponsors.each do |sponsor| %>
          <div class="col">
            <div class="card h-100 shadow-sm text-center">
              <div class="card-body d-flex flex-column align-items-center justify-content-center py-4">
                <% if sponsor.logo.attached? %>
                  <%= image_tag sponsor.logo.variant(resize_to_limit: [300, 120]),
                        style: 'max-height: 80px; max-width: 180px; object-fit: contain;',
                        alt: sponsor.name %>
                <% else %>
                  <i class="bi bi-trophy text-muted mb-2" style="font-size: 2rem;"></i>
                <% end %>
                <h6 class="mt-3 mb-0"><%= sponsor.name %></h6>
              </div>
              <div class="card-footer bg-transparent">
                <%= link_to 'Learn More', public_sponsor_path(sponsor), class: 'btn btn-sm btn-outline-secondary' %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

<% else %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-trophy" style="font-size: 3rem;"></i>
    <p class="mt-3">No sponsors listed yet.</p>
  </div>
<% end %>
