<% content_for :title, 'Join an Event' %>

<div style="padding: 20px 0 24px;">
  <h1 style="font-family:'Syne',sans-serif; font-size:24px; font-weight:800; letter-spacing:-0.02em;">
    Join an Event
  </h1>
  <p style="font-size:14px; color:rgba(255,255,255,0.45); margin-top:8px; line-height:1.5;">
    Register <%= @vendor.name %> as a participant in an upcoming event.
  </p>
</div>

<% if @vendor_event.errors.any? %>
  <div class="vd-errors">
    <% @vendor_event.errors.full_messages.each do |msg| %>
      <p><%= msg %></p>
    <% end %>
  </div>
<% end %>

<%= form_with model: [:vendor, @vendor, @vendor_event] do |f| %>

  <div class="vd-form-section">
    <div class="vd-form-section__title">Participation</div>

    <div class="vd-field">
      <%= f.label :category, 'Participation Type', class: 'vd-label' %>
      <%= f.select :category,
                   [
                     ["Dealer's Room",  'dealer'],
                     ['Artist Alley',   'artist_alley'],
                     ['Sponsor',        'sponsor'],
                     ['Exhibitor',      'exhibitor'],
                     ['Panelist',       'panelist']
                   ],
                   { selected: @vendor_event.category.presence || default_category },
                   class: 'vd-input' %>
      <span class="vd-hint">How you're participating at this event</span>
    </div>

    <div class="vd-field">
      <%= f.label :event_id, 'Select Event', class: 'vd-label' %>
      <% if @available_events.any? %>
        <%= f.select :event_id,
                     @available_events.map { |e|
                       ["#{e.name}  ·  #{e.event_date.strftime('%b %-d, %Y')}", e.id]
                     },
                     { include_blank: 'Choose an event...' },
                     class: "vd-input #{'is-invalid' if @vendor_event.errors[:event_id].any?}" %>
      <% else %>
        <div class="vd-card">
          <div class="vd-empty" style="padding: 24px;">
            <div class="vd-empty__icon">📅</div>
            <p class="vd-empty__text">No upcoming events available.<br>Ask the organiser to add one.</p>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <% if @available_events.any? %>
    <div class="vd-form-section">
      <div class="vd-form-section__title">Booth Location <span style="font-weight:400; opacity:0.5;">(optional)</span></div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
        <div class="vd-field">
          <label class="vd-label" for="vendor_event_booth_number">Booth #</label>
          <input type="text"
                 id="vendor_event_booth_number"
                 name="vendor_event[booth_number]"
                 placeholder="247"
                 class="vd-input"
                 value="<%= @vendor_event.metadata&.dig('booth_number') %>">
        </div>
        <div class="vd-field">
          <label class="vd-label" for="vendor_event_hall">Hall / Section</label>
          <input type="text"
                 id="vendor_event_hall"
                 name="vendor_event[hall]"
                 placeholder="Main Hall A"
                 class="vd-input"
                 value="<%= @vendor_event.metadata&.dig('hall') %>">
        </div>
      </div>
      <p class="vd-hint">Shown to attendees so they can find you.</p>
    </div>

    <div class="vd-form-section">
      <div class="vd-form-section__title">Load-in <span style="font-weight:400; opacity:0.5;">(optional)</span></div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 10px;">
        <div class="vd-field">
          <label class="vd-label" for="vendor_event_load_in_date">Date</label>
          <input type="text"
                 id="vendor_event_load_in_date"
                 name="vendor_event[load_in_date]"
                 placeholder="e.g. Friday April 4"
                 class="vd-input"
                 value="<%= @vendor_event.metadata&.dig('load_in_date') %>">
        </div>
        <div class="vd-field">
          <label class="vd-label" for="vendor_event_load_in_time">Time window</label>
          <input type="text"
                 id="vendor_event_load_in_time"
                 name="vendor_event[load_in_time]"
                 placeholder="e.g. 8 AM – 10 AM"
                 class="vd-input"
                 value="<%= @vendor_event.metadata&.dig('load_in_time') %>">
        </div>
      </div>
      <div class="vd-field">
        <label class="vd-label" for="vendor_event_load_in_notes">Notes</label>
        <textarea id="vendor_event_load_in_notes"
                  name="vendor_event[load_in_notes]"
                  placeholder="e.g. Use loading dock B, check in with venue staff first"
                  class="vd-input"
                  rows="2"><%= @vendor_event.metadata&.dig('load_in_notes') %></textarea>
      </div>
    </div>

    <%= f.submit 'Register for Event', class: 'vd-btn vd-btn--full' %>
  <% end %>

<% end %>
