<div class="container-fluid">
  <div class="row mb-3">
    <div class="col">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Admin", admin_root_path %></li>
          <li class="breadcrumb-item"><%= link_to "Vendors", admin_vendors_path %></li>
          <li class="breadcrumb-item active" aria-current="page"><%= @vendor.name %></li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-md-8">
      <h1>
        <%= @vendor.name %>
        <span class="badge <%= @vendor.artist? ? 'bg-warning text-dark' : 'bg-primary' %> fs-6 align-middle">
          <%= @vendor.artist? ? 'Artist' : 'Business' %>
        </span>
      </h1>
    </div>
    <div class="col-md-4 text-end">
      <%= link_to "Edit Vendor", edit_admin_vendor_path(@vendor), class: "btn btn-primary" %>
      <%= link_to "Delete", admin_vendor_path(@vendor), method: :delete,
          data: { confirm: "Delete #{@vendor.name}? This cannot be undone." },
          class: "btn btn-danger" %>
    </div>
  </div>

  <div class="row">
    <%# ── Main column ── %>
    <div class="col-md-8">

      <%# Vendor details %>
      <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Vendor Details</h5></div>
        <div class="card-body">
          <% if @vendor.hook_line.present? %>
            <p class="lead text-muted mb-3"><em>"<%= @vendor.hook_line %>"</em></p>
          <% end %>

          <% if @vendor.description.present? %>
            <p><strong>Description:</strong></p>
            <%= simple_format(@vendor.description) %>
          <% end %>

          <% if @vendor.website.present? %>
            <p class="mb-1"><strong>Website:</strong>
              <%= link_to @vendor.website, @vendor.website, target: '_blank' %>
            </p>
          <% end %>

          <% handles = @vendor.social_handles %>
          <% if handles.any? %>
            <p class="mb-1 mt-3"><strong>Social:</strong></p>
            <% handles.each do |platform, handle| %>
              <span class="badge bg-secondary me-1"><%= platform.to_s.capitalize %>: @<%= handle %></span>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Events %>
      <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Events (<%= @vendor.vendor_events.count %>)</h5></div>
        <div class="card-body p-0">
          <% if @vendor.vendor_events.any? %>
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Event</th>
                  <th>Date</th>
                  <th>Category</th>
                  <th>Booth</th>
                  <th>Hall</th>
                </tr>
              </thead>
              <tbody>
                <% @vendor.vendor_events.each do |ve| %>
                  <tr>
                    <td><%= link_to ve.event.name, admin_event_path(ve.event) %></td>
                    <td><small><%= ve.event.event_date&.strftime("%b %d, %Y") %></small></td>
                    <td><span class="badge bg-secondary"><%= ve.category&.humanize || '—' %></span></td>
                    <td><%= ve.booth_number.presence || '—' %></td>
                    <td><%= ve.hall.presence || '—' %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <div class="p-3 text-muted">No event appearances yet.</div>
          <% end %>
        </div>
      </div>

    </div>

    <%# ── Sidebar ── %>
    <div class="col-md-4">
      <div class="card mb-3">
        <div class="card-header"><h6 class="mb-0">Owner</h6></div>
        <div class="card-body">
          <p class="mb-1"><strong><%= @vendor.user&.full_name %></strong></p>
          <p class="mb-1 text-muted small"><%= @vendor.user&.email %></p>
          <p class="mb-0 text-muted small"><%= @vendor.user&.phone %></p>
          <% if @vendor.user %>
            <div class="mt-2">
              <%= link_to "View User", admin_user_path(@vendor.user), class: "btn btn-sm btn-outline-secondary" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="card">
        <div class="card-header"><h6 class="mb-0">Quick Actions</h6></div>
        <div class="card-body d-grid gap-2">
          <%= link_to "Edit Vendor", edit_admin_vendor_path(@vendor), class: "btn btn-outline-primary" %>
          <%= link_to "Back to Vendors", admin_vendors_path, class: "btn btn-outline-secondary" %>
          <%= link_to "Delete", admin_vendor_path(@vendor), method: :delete,
              data: { confirm: "Delete #{@vendor.name}?" },
              class: "btn btn-outline-danger" %>
        </div>
      </div>
    </div>
  </div>
</div>
