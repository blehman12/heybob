<%# Header %>
<div class="d-flex align-items-start gap-4 mb-4">
  <% if @sponsor.logo.attached? %>
    <%= image_tag @sponsor.logo.variant(resize_to_limit: [400, 160]),
          style: 'max-height: 100px; max-width: 240px; object-fit: contain;',
          alt: @sponsor.name %>
  <% end %>
  <div>
    <h2 class="mb-1"><%= @sponsor.name %></h2>
    <span class="badge fs-6 <%= @sponsor.tier_badge_class %>">
      <%= @sponsor.tier_label %> Sponsor
    </span>
  </div>
</div>

<div class="row">

  <%# ── Main content ── %>
  <div class="col-md-8">

    <% if @sponsor.description.present? %>
      <div class="card mb-4">
        <div class="card-body">
          <%= simple_format(@sponsor.description) %>
        </div>
      </div>
    <% end %>

    <%# Events %>
    <% if @sponsor.sponsor_events.any? %>
      <h5 class="mb-3"><i class="bi bi-calendar-event"></i> Sponsoring</h5>
      <% @sponsor.sponsor_events.each do |se| %>
        <div class="card mb-3 shadow-sm">
          <div class="card-body">
            <h6 class="mb-1">
              <%= link_to se.event.name, public_event_path(se.event.slug), class: 'text-decoration-none fw-semibold' %>
            </h6>
            <p class="text-muted small mb-0">
              <i class="bi bi-calendar3"></i> <%= se.event.event_date&.strftime('%A, %B %-d, %Y') %>
            </p>
          </div>
        </div>
      <% end %>
    <% end %>

  </div>

  <%# ── Sidebar ── %>
  <div class="col-md-4">

    <% if @sponsor.website.present? %>
      <div class="card mb-3">
        <div class="card-body d-grid">
          <%= link_to @sponsor.website, target: '_blank', rel: 'noopener', class: 'btn btn-outline-primary' do %>
            <i class="bi bi-globe"></i> Visit <%= @sponsor.name %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="d-grid">
      <%= link_to 'All Sponsors', public_sponsors_path, class: 'btn btn-outline-secondary btn-sm' %>
    </div>

  </div>

</div>
