<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="text-center mb-4">
        <h1 class="mb-1">Stay in the Loop</h1>
        <p class="text-muted">Sign up to hear about upcoming events, workshops, and meetups in your area.</p>
      </div>

      <div class="card shadow-sm">
        <div class="card-body p-4">

          <% if @interest_signup.errors.any? %>
            <div class="alert alert-danger">
              <ul class="mb-0">
                <% @interest_signup.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%= form_with model: @interest_signup, url: interest_signup_path, local: true do |f| %>
            <%= f.hidden_field :source, value: params[:source] %>

            <div class="mb-3">
              <%= f.label :name, "Your Name", class: "form-label fw-semibold" %>
              <%= f.text_field :name, class: "form-control", placeholder: "First and last name", autofocus: true %>
            </div>

            <div class="mb-3">
              <%= f.label :email, "Email Address", class: "form-label fw-semibold" %>
              <%= f.email_field :email, class: "form-control", placeholder: "you@example.com" %>
            </div>

            <div class="mb-3">
              <%= f.label :phone, "Phone Number", class: "form-label fw-semibold" %>
              <small class="text-muted ms-1">(optional — for SMS updates)</small>
              <%= f.telephone_field :phone, class: "form-control", placeholder: "503-555-0100" %>
            </div>

            <div class="mb-4">
              <%= f.label :notes, "Anything you'd like us to know?", class: "form-label fw-semibold" %>
              <small class="text-muted ms-1">(optional)</small>
              <%= f.text_area :notes, class: "form-control", rows: 3,
                              placeholder: "Topics you're interested in, events you'd like to see, etc." %>
            </div>

            <%= f.submit "Sign Me Up", class: "btn btn-primary w-100 btn-lg" %>
          <% end %>

        </div>
      </div>

      <p class="text-center text-muted mt-3" style="font-size:.85rem;">
        No spam. Unsubscribe any time.
      </p>

    </div>
  </div>
</div>
