<div class="container py-5">

  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <h1 class="mb-1">Upcoming Events</h1>
      <% if @active_tag %>
        <div class="d-flex align-items-center gap-2 mt-2">
          <span class="text-muted">Filtered by:</span>
          <span class="badge rounded-pill border fw-normal px-3 py-2"
                style="font-size:.85rem; color:#495057; background:#f8f9fa;">
            <%= @active_tag.name %>
          </span>
          <%= link_to public_events_path, class: 'btn btn-sm btn-outline-secondary' do %>
            <i class="bi bi-x"></i> Clear filter
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Events List -->
  <% if @events.any? %>
    <div class="row g-4">
      <% @events.each do |event| %>
        <div class="col-12">
          <div class="card shadow-sm">
            <div class="card-body">
              <div class="row align-items-start">

                <!-- Date column -->
                <div class="col-auto text-center me-3">
                  <div class="bg-primary text-white rounded px-3 py-2" style="min-width:60px;">
                    <div class="fw-bold" style="font-size:1.4rem; line-height:1;">
                      <%= event.event_date.strftime('%d') %>
                    </div>
                    <div style="font-size:.75rem; text-transform:uppercase; letter-spacing:.05em;">
                      <%= event.event_date.strftime('%b') %>
                    </div>
                    <div style="font-size:.75rem;">
                      <%= event.event_date.strftime('%Y') %>
                    </div>
                  </div>
                </div>

                <!-- Event details -->
                <div class="col">
                  <h4 class="mb-1">
                    <%= link_to event.name, public_event_path(event.slug), class: 'text-decoration-none text-dark' %>
                  </h4>

                  <div class="text-muted mb-2" style="font-size:.9rem;">
                    <% if event.start_time.present? %>
                      <i class="bi bi-clock"></i>
                      <%= event.start_time.strftime('%I:%M %p') %>
                      <% if event.end_time.present? %>
                        &ndash; <%= event.end_time.strftime('%I:%M %p') %>
                      <% end %>
                      &nbsp;&middot;&nbsp;
                    <% end %>
                    <% if event.venue.present? %>
                      <i class="bi bi-geo-alt"></i>
                      <%= event.venue.name %>
                    <% else %>
                      <i class="bi bi-geo-alt"></i>
                      Location TBD
                    <% end %>
                  </div>

                  <% if event.description.present? %>
                    <p class="text-muted mb-2" style="font-size:.9rem;">
                      <%= truncate(event.description, length: 160) %>
                    </p>
                  <% end %>

                  <!-- Category pills -->
                  <% if event.categories.any? %>
                    <div class="d-flex flex-wrap gap-2 mb-2">
                      <% event.categories.each do |cat| %>
                        <%= link_to public_events_path(tag: cat.slug),
                                    class: "badge rounded-pill border fw-normal px-3 py-2 text-decoration-none #{'border-primary' if @active_tag&.id == cat.id}",
                                    style: "font-size:.8rem; color:#495057; background:#f8f9fa;" do %>
                          <%= cat.name %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>

                <!-- CTA -->
                <div class="col-auto d-flex align-items-center">
                  <%= link_to public_event_path(event.slug),
                              class: "btn #{ event.rsvp_available? ? 'btn-primary' : 'btn-outline-secondary' }" do %>
                    <% if event.rsvp_available? %>
                      RSVP
                    <% else %>
                      View Details
                    <% end %>
                  <% end %>
                </div>

              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>

  <% else %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-calendar-x" style="font-size:3rem;"></i>
      <p class="mt-3 mb-0">
        <% if @active_tag %>
          No upcoming events tagged <strong><%= @active_tag.name %></strong>.
          <%= link_to 'View all events', public_events_path %>
        <% else %>
          No upcoming events at this time. Check back soon.
        <% end %>
      </p>
    </div>
  <% end %>

</div>
