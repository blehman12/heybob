<div class="d-flex align-items-center justify-content-between mb-3">
  <h4 class="mb-0"><i class="bi bi-stars"></i> Guests</h4>
</div>

<%# Type filter %>
<div class="d-flex gap-2 flex-wrap mb-4">
  <%= link_to 'All', public_guests_path,
        class: "btn btn-sm #{@active_type.blank? ? 'btn-primary' : 'btn-outline-secondary'}" %>
  <% Guest.guest_types.keys.each do |type| %>
    <%= link_to Guest.new(guest_type: type).guest_type_label, public_guests_path(type: type),
          class: "btn btn-sm #{@active_type == type ? 'btn-primary' : 'btn-outline-secondary'}" %>
  <% end %>
</div>

<% if @guests.any? %>
  <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    <% @guests.each do |guest| %>
      <div class="col">
        <div class="card h-100 shadow-sm text-center">

          <%# Photo %>
          <div class="pt-4 px-4">
            <% if guest.photo.attached? %>
              <%= image_tag guest.photo.variant(resize_to_limit: [300, 300]),
                    class: 'rounded-circle mx-auto d-block',
                    style: 'width: 100px; height: 100px; object-fit: cover;',
                    alt: guest.name %>
            <% else %>
              <div class="rounded-circle mx-auto d-flex align-items-center justify-content-center bg-light"
                   style="width: 100px; height: 100px;">
                <i class="bi bi-person text-muted" style="font-size: 2.5rem;"></i>
              </div>
            <% end %>
          </div>

          <div class="card-body">
            <h6 class="card-title mb-1"><%= guest.name %></h6>
            <span class="badge <%= guest.guest_type_badge_class %> mb-2">
              <%= guest.guest_type_label %>
            </span>
            <% if guest.bio.present? %>
              <p class="card-text small text-muted">
                <%= truncate(guest.bio, length: 80) %>
              </p>
            <% end %>
          </div>

          <div class="card-footer bg-transparent">
            <%= link_to 'View Profile', public_guest_path(guest), class: 'btn btn-sm btn-outline-primary' %>
          </div>

        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-stars" style="font-size: 3rem;"></i>
    <p class="mt-3">No guests found.</p>
  </div>
<% end %>
