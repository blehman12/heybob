<div class="row">

  <%# ── Main: My Events ── %>
  <div class="col-md-8">

    <div class="d-flex align-items-center justify-content-between mb-4">
      <h4 class="mb-0"><i class="bi bi-calendar-event"></i> My Events</h4>
      <%= link_to 'Browse All Events', public_events_path, class: 'btn btn-sm btn-outline-primary' %>
    </div>

    <% if @upcoming_participants.any? %>
      <% @upcoming_participants.each do |participant| %>
        <% event = participant.event %>
        <%
          s = participant.rsvp_status.to_s
          status_label = { 'yes' => 'Going', 'maybe' => 'Maybe', 'no' => 'Not Going', 'pending' => 'Invited' }
          status_color = { 'yes' => 'success', 'maybe' => 'warning', 'no' => 'danger', 'pending' => 'secondary' }
        %>
        <div class="card mb-3 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <div class="flex-grow-1 min-w-0">
                <h5 class="card-title mb-1"><%= event.name %></h5>
                <p class="text-muted small mb-0">
                  <i class="bi bi-calendar3"></i>
                  <%= event.event_date&.strftime('%A, %B %-d, %Y') %>
                  <% if event.venue.present? %>
                    &nbsp;·&nbsp;<i class="bi bi-geo-alt"></i> <%= event.venue.name %>
                  <% end %>
                </p>
              </div>
              <div class="text-end flex-shrink-0">
                <span class="badge bg-<%= status_color[s] || 'secondary' %> px-3 py-2">
                  <%= status_label[s] || s.humanize %>
                </span>
                <% if participant.vendor? %>
                  <br><span class="badge bg-warning text-dark mt-1">Vendor</span>
                <% elsif participant.organizer? %>
                  <br><span class="badge bg-info text-dark mt-1">Organizer</span>
                <% end %>
                <% if participant.checked_in? %>
                  <br><small class="text-success mt-1 d-block">
                    <i class="bi bi-check-circle-fill"></i> Checked in
                  </small>
                <% end %>
              </div>
            </div>

            <div class="d-flex gap-2 mt-3 flex-wrap">
              <%= link_to public_event_path(event.slug), class: 'btn btn-sm btn-outline-primary' do %>
                <i class="bi bi-arrow-right-circle"></i> View Event
              <% end %>
              <% if s == 'yes' && event.rsvp_open? %>
                <%= link_to public_event_path(event.slug), class: 'btn btn-sm btn-outline-secondary' do %>
                  <i class="bi bi-pencil"></i> Update RSVP
                <% end %>
              <% end %>
              <% if s == 'yes' %>
                <%= link_to public_event_calendar_path(event.slug), class: 'btn btn-sm btn-outline-success' do %>
                  <i class="bi bi-calendar-plus"></i> Add to Calendar
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    <% else %>
      <div class="card border-0 bg-light">
        <div class="card-body text-center py-5">
          <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
          <h5 class="text-muted mt-3">No upcoming events</h5>
          <p class="text-muted mb-3">Browse events to find something you'd like to attend.</p>
          <%= link_to 'Browse Events', public_events_path, class: 'btn btn-primary' %>
        </div>
      </div>
    <% end %>

    <% if @past_participants.any? %>
      <h6 class="text-muted mt-4 mb-3">
        <i class="bi bi-clock-history"></i> Past Events
      </h6>
      <% @past_participants.each do |participant| %>
        <% event = participant.event %>
        <% s = participant.rsvp_status.to_s %>
        <% status_color = { 'yes' => 'success', 'maybe' => 'warning', 'no' => 'danger', 'pending' => 'secondary' } %>
        <div class="card mb-2 border-0 bg-light">
          <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
            <div>
              <span class="fw-semibold text-muted"><%= event.name %></span>
              <small class="text-muted ms-2">
                <i class="bi bi-calendar3"></i> <%= event.event_date&.strftime('%b %-d, %Y') %>
              </small>
            </div>
            <% if participant.checked_in? %>
              <span class="badge bg-success">
                <i class="bi bi-check-circle"></i> Attended
              </span>
            <% else %>
              <span class="badge bg-<%= status_color[s] || 'secondary' %>">
                <%= s.humanize %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

  </div>

  <%# ── Sidebar ── %>
  <div class="col-md-4">

    <div class="card mb-3">
      <div class="card-header">
        <h5 class="mb-0"><i class="bi bi-person-circle"></i> Your Profile</h5>
      </div>
      <div class="card-body">
        <p class="mb-1 fw-semibold"><%= current_user.full_name %></p>
        <p class="text-muted small mb-1"><%= current_user.email %></p>
        <% if current_user.company.present? %>
          <p class="text-muted small mb-1"><%= current_user.company %></p>
        <% end %>
        <% if current_user.phone.present? %>
          <p class="text-muted small mb-2"><%= current_user.phone %></p>
        <% end %>
        <% if current_user.admin? %>
          <span class="badge bg-primary mb-2">Administrator</span><br>
        <% end %>
        <%= link_to 'Edit Profile', edit_profile_path, class: 'btn btn-outline-primary btn-sm d-block' %>
      </div>
    </div>

    <% if current_user.admin? %>
      <div class="card">
        <div class="card-header">
          <h6 class="mb-0"><i class="bi bi-gear"></i> Admin</h6>
        </div>
        <div class="card-body">
          <div class="d-grid gap-2">
            <%= link_to 'Admin Dashboard', admin_root_path, class: 'btn btn-sm btn-outline-primary' %>
            <%= link_to 'Manage Events',   admin_events_path, class: 'btn btn-sm btn-outline-success' %>
            <%= link_to 'Manage Users',    admin_users_path,  class: 'btn btn-sm btn-outline-info' %>
          </div>
        </div>
      </div>
    <% end %>

  </div>
</div>
