<% if current_user %>

  <%# ═══════════════════════════════════════════════════════════ %>
  <%#  LOGGED-IN ATTENDEE DASHBOARD                               %>
  <%# ═══════════════════════════════════════════════════════════ %>

  <div class="row">

    <%# ── Main column ── %>
    <div class="col-md-8">

      <%# ── Pending invitations (action required) ── %>
      <% if @pending_participants.any? %>
        <div class="alert alert-warning d-flex align-items-start gap-3 mb-4" role="alert">
          <i class="bi bi-envelope-exclamation fs-4 flex-shrink-0 mt-1"></i>
          <div class="flex-grow-1">
            <h6 class="alert-heading mb-1">You have <%= pluralize(@pending_participants.size, 'pending invitation') %></h6>
            <% @pending_participants.each do |p| %>
              <div class="d-flex justify-content-between align-items-center py-1 border-bottom border-warning-subtle">
                <span><strong><%= p.event.name %></strong> &middot; <small class="text-muted"><%= p.event.event_date&.strftime('%b %-d') %></small></span>
                <%= link_to 'Respond', public_event_path(p.event.slug), class: 'btn btn-sm btn-warning' %>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# ── Upcoming confirmed / maybe events ── %>
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h4 class="mb-0"><i class="bi bi-calendar-event"></i> My Events</h4>
        <%= link_to 'Browse All Events', root_path(show_all: 'true'), class: 'btn btn-sm btn-outline-primary' %>
      </div>

      <% if @confirmed_participants.any? %>
        <% @confirmed_participants.each do |participant| %>
          <% event = participant.event %>
          <%
            s = participant.rsvp_status.to_s
            status_label = { 'yes' => 'Going', 'maybe' => 'Maybe' }
            status_color = { 'yes' => 'success', 'maybe' => 'warning' }
          %>
          <div class="card mb-3 shadow-sm">
            <div class="card-body">
              <div class="row g-3 align-items-start">

                <%# Event info %>
                <div class="col">
                  <h5 class="card-title mb-1"><%= event.name %></h5>
                  <p class="text-muted small mb-2">
                    <i class="bi bi-calendar3"></i> <%= event.event_date&.strftime('%A, %B %-d, %Y') %>
                    <% if event.venue.present? %>
                      &nbsp;&middot;&nbsp;<i class="bi bi-geo-alt"></i> <%= event.venue.name %>
                    <% end %>
                  </p>

                  <div class="mb-2">
                    <span class="badge bg-<%= status_color[s] || 'secondary' %> px-3 py-2">
                      <%= status_label[s] || s.humanize %>
                    </span>
                    <% if participant.checked_in? %>
                      <span class="badge bg-success ms-1"><i class="bi bi-check-circle-fill"></i> Checked in</span>
                    <% end %>
                  </div>

                  <div class="d-flex gap-2 flex-wrap">
                    <%= link_to public_event_path(event.slug), class: 'btn btn-sm btn-outline-primary' do %>
                      <i class="bi bi-arrow-right-circle"></i> View Event
                    <% end %>
                    <% if s == 'yes' %>
                      <%= link_to public_event_calendar_path(event.slug), class: 'btn btn-sm btn-outline-success' do %>
                        <i class="bi bi-calendar-plus"></i> Add to Calendar
                      <% end %>
                    <% end %>
                    <% if event.rsvp_open? %>
                      <%= link_to public_event_path(event.slug), class: 'btn btn-sm btn-outline-secondary' do %>
                        <i class="bi bi-pencil"></i> Update RSVP
                      <% end %>
                    <% end %>
                  </div>
                </div>

                <%# Inline QR code for confirmed attendees %>
                <% if s == 'yes' && participant.qr_code_token.present? %>
                  <div class="col-auto text-center">
                    <% qr_url = participant.qr_code_data %>
                    <% if qr_url %>
                      <% qr = RQRCode::QRCode.new(qr_url) %>
                      <div style="width:120px;">
                        <%= qr.as_svg(color: "000", shape_rendering: "crispEdges", module_size: 3,
                                      standalone: true, use_path: true).html_safe %>
                      </div>
                      <small class="text-muted d-block mt-1" style="font-size:0.7rem;">Your check-in code</small>
                    <% end %>
                  </div>
                <% end %>

              </div>
            </div>
          </div>
        <% end %>

      <% else %>
        <div class="card border-0 bg-light mb-4">
          <div class="card-body text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size:3rem;"></i>
            <h5 class="text-muted mt-3">No upcoming events</h5>
            <p class="text-muted mb-3">Browse events below to find something you'd like to attend.</p>
          </div>
        </div>
      <% end %>

      <%# ── Past events (compact) ── %>
      <% if @past_participants.any? %>
        <h6 class="text-muted mt-2 mb-2"><i class="bi bi-clock-history"></i> Past Events</h6>
        <% @past_participants.each do |participant| %>
          <% event = participant.event %>
          <div class="card mb-2 border-0 bg-light">
            <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center">
              <div>
                <span class="fw-semibold text-muted"><%= event.name %></span>
                <small class="text-muted ms-2"><%= event.event_date&.strftime('%b %-d, %Y') %></small>
              </div>
              <% if participant.checked_in? %>
                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Attended</span>
              <% else %>
                <span class="badge bg-secondary"><%= participant.rsvp_status.to_s.humanize %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      <% end %>

      <%# ── Discover Events ── %>
      <div class="d-flex align-items-center justify-content-between mt-4 mb-3">
        <h4 class="mb-0"><i class="bi bi-compass"></i> Discover Events</h4>
        <% if @has_interests && @showing_matched %>
          <%= link_to root_path(show_all: 'true'), class: 'btn btn-sm btn-outline-secondary' do %>
            <i class="bi bi-grid"></i> Show All
          <% end %>
        <% elsif @has_interests && !@showing_matched %>
          <%= link_to root_path, class: 'btn btn-sm btn-outline-primary' do %>
            <i class="bi bi-stars"></i> Show Matches
          <% end %>
        <% end %>
      </div>

      <% unless @has_interests %>
        <div class="alert alert-info d-flex gap-2 align-items-center mb-3" role="alert">
          <i class="bi bi-stars fs-5"></i>
          <div>
            Get personalized suggestions — <strong><%= link_to 'add your interests', edit_profile_path, class: 'alert-link' %></strong> to your profile.
          </div>
        </div>
      <% end %>

      <% if @discover_events.any? %>
        <% @discover_events.each do |event| %>
          <div class="card mb-3 border-0 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <h6 class="mb-1"><%= link_to event.name, public_event_path(event.slug), class: 'text-decoration-none fw-semibold' %></h6>
                  <p class="text-muted small mb-1">
                    <i class="bi bi-calendar3"></i> <%= event.event_date&.strftime('%b %-d, %Y') %>
                    <% if event.venue.present? %>
                      &nbsp;&middot;&nbsp;<i class="bi bi-geo-alt"></i> <%= event.venue.name %>
                    <% end %>
                  </p>
                  <% event.categories.each do |cat| %>
                    <span class="badge bg-secondary me-1" style="font-size:0.7rem;"><%= cat.name %></span>
                  <% end %>
                </div>
                <%= link_to 'View', public_event_path(event.slug), class: 'btn btn-sm btn-outline-primary flex-shrink-0 ms-3' %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-muted">No upcoming events to discover right now.</p>
      <% end %>

    </div>

    <%# ── Sidebar ── %>
    <div class="col-md-4">

      <div class="card mb-3">
        <div class="card-header"><h5 class="mb-0"><i class="bi bi-person-circle"></i> Your Profile</h5></div>
        <div class="card-body">
          <% if current_user.avatar.attached? %>
            <div class="text-center mb-3">
              <%= image_tag current_user.avatar, class: "rounded-circle", style: "width:80px;height:80px;object-fit:cover;" %>
            </div>
          <% end %>
          <p class="mb-1 fw-semibold"><%= current_user.full_name %></p>
          <p class="text-muted small mb-1"><%= current_user.email %></p>
          <% if current_user.company.present? %>
            <p class="text-muted small mb-0"><%= current_user.company %></p>
          <% end %>
          <div class="mt-3">
            <%= link_to 'Edit Profile', edit_profile_path, class: 'btn btn-outline-primary btn-sm d-block' %>
          </div>
        </div>
      </div>

    </div>

  </div>

<% else %>

  <%# ═══════════════════════════════════════════════════════════ %>
  <%#  PUBLIC / LOGGED-OUT DISCOVERY VIEW                         %>
  <%# ═══════════════════════════════════════════════════════════ %>

  <div class="d-flex align-items-center justify-content-between mb-3">
    <h4 class="mb-0"><i class="bi bi-compass"></i> Upcoming Events</h4>
    <% if @active_tag %>
      <%= link_to 'Show All', root_path, class: 'btn btn-sm btn-outline-secondary' %>
    <% end %>
  </div>

  <%# Category filter bar %>
  <% if @categories&.any? %>
    <div class="d-flex flex-wrap gap-2 mb-4">
      <% @categories.each do |cat| %>
        <%= link_to cat.name, root_path(tag: cat.slug),
              class: "btn btn-sm #{@active_tag&.id == cat.id ? 'btn-primary' : 'btn-outline-secondary'}" %>
      <% end %>
    </div>
  <% end %>

  <% if @discover_events.any? %>
    <div class="row row-cols-1 row-cols-md-2 g-3">
      <% @discover_events.each do |event| %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title"><%= link_to event.name, public_event_path(event.slug), class: 'text-decoration-none' %></h5>
              <p class="text-muted small mb-2">
                <i class="bi bi-calendar3"></i> <%= event.event_date&.strftime('%A, %B %-d, %Y') %>
              </p>
              <% if event.venue.present? %>
                <p class="text-muted small mb-2">
                  <i class="bi bi-geo-alt"></i> <%= event.venue.name %>
                </p>
              <% end %>
              <% event.categories.each do |cat| %>
                <span class="badge bg-secondary me-1" style="font-size:0.7rem;"><%= cat.name %></span>
              <% end %>
            </div>
            <div class="card-footer bg-transparent">
              <%= link_to 'View Event', public_event_path(event.slug), class: 'btn btn-sm btn-primary' %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-calendar-x" style="font-size:3rem;"></i>
      <p class="mt-3">No upcoming events found.</p>
    </div>
  <% end %>

<% end %>
