<div class="row justify-content-center">
  <div class="col-md-8">
    <div class="card">
      <div class="card-body">
        <%= form_with(model: [:admin, @sponsor], local: true, multipart: true) do |form| %>
          <% if @sponsor.errors.any? %>
            <div class="alert alert-danger">
              <h4><%= pluralize(@sponsor.errors.count, "error") %> prohibited this sponsor from being saved:</h4>
              <ul class="mb-0">
                <% @sponsor.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <%# Logo %>
          <div class="mb-3">
            <%= form.label :logo, "Logo", class: "form-label" %>
            <% if @sponsor.logo.attached? %>
              <div class="mb-2">
                <%= image_tag @sponsor.logo.variant(resize_to_limit: [300, 120]),
                      class: "img-thumbnail",
                      style: "max-height: 80px; object-fit: contain; background: #f8f9fa;" %>
                <div class="form-text">Current logo — upload a new one to replace it.</div>
              </div>
            <% end %>
            <%= form.file_field :logo, class: "form-control", accept: "image/*" %>
            <div class="form-text">JPG, PNG, or WebP · Max 2 MB · Transparent PNG recommended</div>
          </div>

          <%# Name %>
          <div class="mb-3">
            <%= form.label :name, class: "form-label" %>
            <%= form.text_field :name, class: "form-control", required: true %>
          </div>

          <%# Tier %>
          <div class="mb-3">
            <%= form.label :tier, "Sponsorship Tier", class: "form-label fw-bold" %>
            <%= form.select :tier,
                  Sponsor.tiers.keys.map { |t| [t.capitalize, t] },
                  {},
                  class: "form-select" %>
          </div>

          <%# Description %>
          <div class="mb-3">
            <%= form.label :description, class: "form-label" %>
            <%= form.text_area :description, class: "form-control", rows: 3,
                  placeholder: "Brief description shown on the public sponsor profile." %>
          </div>

          <%# Website %>
          <div class="mb-3">
            <%= form.label :website, class: "form-label" %>
            <%= form.url_field :website, class: "form-control", placeholder: "https://example.com" %>
          </div>

          <%# Display order %>
          <div class="mb-3">
            <%= form.label :display_order, "Display Order", class: "form-label" %>
            <%= form.number_field :display_order, class: "form-control", style: "width: 100px;", min: 0 %>
            <div class="form-text">Lower numbers appear first within the same tier.</div>
          </div>

          <%# Active toggle %>
          <div class="mb-3 form-check">
            <%= form.check_box :is_active, class: "form-check-input" %>
            <%= form.label :is_active, "Active (visible on public sponsor page)", class: "form-check-label" %>
          </div>

          <div class="d-grid gap-2 d-md-flex justify-content-md-end">
            <%= link_to "Cancel", admin_sponsors_path, class: "btn btn-outline-secondary me-md-2" %>
            <%= form.submit class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
