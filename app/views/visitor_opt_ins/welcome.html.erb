<% content_for :title, "You're In!" %>

<div class="welcome-screen">

  <%# Animated checkmark %>
  <div class="welcome-checkmark">
    <svg viewBox="0 0 24 24">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
  </div>

  <h1 class="welcome-headline">
    You're<br>
    <span class="welcome-vendor">In!</span>
  </h1>

  <% event_day = @vendor_event.event.event_date <= Date.today %>
  <p class="welcome-body">
    You're now following
    <strong style="color: white;"><%= @vendor_event.vendor.name %></strong>
    at <%= @vendor_event.event.name %>.
  </p>

  <div class="welcome-cards">

    <% if @vendor_event.vendor.hook_line.present? %>
      <div class="welcome-card">
        <span class="welcome-card__icon">💬</span>
        <div class="welcome-card__text">
          <strong>From <%= @vendor_event.vendor.name %></strong>
          <%= @vendor_event.vendor.hook_line %>
        </div>
      </div>
    <% end %>

    <% booth = @vendor_event.metadata&.dig('booth_number') %>
    <% hall  = @vendor_event.metadata&.dig('hall') %>
    <% if booth.present? %>
      <div class="welcome-card">
        <span class="welcome-card__icon">📍</span>
        <div class="welcome-card__text">
          <strong><%= event_day ? 'Find us' : 'Our booth' %></strong>
          <%= @vendor_event.vendor.name %>
          — Booth <%= booth %><%= hall.present? ? ", #{hall}" : '' %>
        </div>
      </div>
    <% end %>

    <% if @sms_opted_in %>
      <% if event_day %>
        <div class="welcome-card">
          <span class="welcome-card__icon">📲</span>
          <div class="welcome-card__text">
            <strong>Stay tuned</strong>
            You'll get text updates about specials,
            drawings, and events happening right now on the floor.
          </div>
        </div>
      <% else %>
        <div class="welcome-card">
          <span class="welcome-card__icon">📲</span>
          <div class="welcome-card__text">
            <strong>You're on the list</strong>
            We'll text you with specials and updates when
            <%= @vendor_event.event.name %> kicks off on
            <%= @vendor_event.event.event_date.strftime('%B %-d') %>.
          </div>
        </div>
      <% end %>
    <% end %>

    <% handles = @vendor_event.vendor.social_handles %>
    <% if handles[:instagram].present? || handles[:tiktok].present? %>
      <div class="welcome-card">
        <span class="welcome-card__icon">📱</span>
        <div class="welcome-card__text">
          <strong>Follow us online</strong>
          <% if handles[:instagram].present? %>
            <a href="https://instagram.com/<%= handles[:instagram] %>" target="_blank"
               style="color:rgba(255,255,255,.85); margin-right:8px;">@<%= handles[:instagram] %> (IG)</a>
          <% end %>
          <% if handles[:tiktok].present? %>
            <a href="https://tiktok.com/@<%= handles[:tiktok] %>" target="_blank"
               style="color:rgba(255,255,255,.85);">@<%= handles[:tiktok] %> (TikTok)</a>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>

  <% if event_day %>
    <%= link_to event_feed_path(@vendor_event.event.slug), class: 'btn-feed' do %>
      See what's happening now →
    <% end %>
  <% else %>
    <%= link_to public_vendor_path(@vendor_event.vendor), class: 'btn-feed' do %>
      View <%= @vendor_event.vendor.name %>'s profile →
    <% end %>
  <% end %>

</div>
