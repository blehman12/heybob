<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>Sponsors</h1>
  <div class="btn-group">
    <%= link_to 'New Sponsor', new_admin_sponsor_path, class: 'btn btn-primary' %>
  </div>
</div>

<% if @sponsors.empty? %>
  <div class="alert alert-info">
    No sponsors yet. <%= link_to 'Add the first sponsor', new_admin_sponsor_path %>.
  </div>
<% else %>
  <div class="card">
    <div class="card-body p-0">
      <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
          <tr>
            <th style="width: 52px;"></th>
            <th>Name</th>
            <th>Tier</th>
            <th>Events</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @sponsors.each do |sponsor| %>
            <tr>
              <td class="px-3">
                <% if sponsor.logo.attached? %>
                  <%= image_tag sponsor.logo.variant(resize_to_limit: [80, 80]),
                        style: 'width: 40px; height: 40px; object-fit: contain; border-radius: 4px; background: #f8f9fa; padding: 2px;',
                        alt: '' %>
                <% else %>
                  <div style="width: 40px; height: 40px; border-radius: 4px; background: #e9ecef;
                               display: flex; align-items: center; justify-content: center;">
                    <i class="bi bi-star text-muted" style="font-size: 1rem;"></i>
                  </div>
                <% end %>
              </td>
              <td><strong><%= link_to sponsor.name, admin_sponsor_path(sponsor) %></strong></td>
              <td>
                <span class="badge <%= sponsor.tier_badge_class %>">
                  <%= sponsor.tier_label %>
                </span>
              </td>
              <td><span class="badge bg-secondary"><%= sponsor.events.size %></span></td>
              <td>
                <% if sponsor.is_active? %>
                  <span class="badge bg-success">Active</span>
                <% else %>
                  <span class="badge bg-secondary">Inactive</span>
                <% end %>
              </td>
              <td class="text-end">
                <%= link_to 'Edit', edit_admin_sponsor_path(sponsor), class: 'btn btn-sm btn-outline-primary' %>
                <%= link_to 'Delete', admin_sponsor_path(sponsor),
                    data: { turbo_method: :delete, turbo_confirm: "Delete #{sponsor.name}?" },
                    class: 'btn btn-sm btn-outline-danger' %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-3">
    <p class="text-muted mb-0"><%= pluralize(@sponsors.total_count, 'sponsor') %> total</p>
    <%= paginate @sponsors %>
  </div>
<% end %>
