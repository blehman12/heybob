<% content_for :title, @vendor_event.vendor.name %>

<div class="optin-screen">

  <%# ── Hero image ── %>
  <div class="optin-hero <%= @vendor_event.vendor.hero_image.attached? ? '' : 'optin-hero--placeholder' %>">
    <% if @vendor_event.vendor.hero_image.attached? %>
      <%= image_tag @vendor_event.vendor.hero_image.variant(resize_to_limit: [1200, 400]),
                    class: 'optin-hero__image',
                    alt: @vendor_event.vendor.name %>
    <% else %>
      <div class="placeholder-icon">🎉</div>
    <% end %>
    <div class="con-badge"><%= @vendor_event.event.name %></div>
  </div>

  <%# ── Card slides up over hero ── %>
  <div class="optin-card">

    <div>
      <h1 class="vendor-name"><%= @vendor_event.vendor.name %></h1>
      <p class="optin-headline"><%= @vendor_event.optin_headline %></p>
      <% if @vendor_event.vendor.hook_line.present? %>
        <p class="hook-line"><%= @vendor_event.vendor.hook_line %></p>
      <% else %>
        <p class="hook-line"><%= @vendor_event.optin_subtext %></p>
      <% end %>
    </div>

    <%# ── Errors ── %>
    <% if @con_opt_in.errors.any? %>
      <div class="form-errors">
        <% @con_opt_in.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <%# ── Form ── %>
    <%= form_with model: @con_opt_in,
                  url: vendor_optin_path(@vendor_event.qr_token),
                  class: 'optin-form' do |f| %>

      <div class="field-group">
        <%= f.label :name, 'Your Name', class: 'field-label' %>
        <%= f.text_field :name,
                         placeholder: 'First name is fine',
                         class: "field-input #{'is-invalid' if @con_opt_in.errors[:name].any?}",
                         autocomplete: 'name',
                         autocapitalize: 'words',
                         required: true %>
      </div>

      <%# ── SMS opt-in — voluntary, unchecked by default ── %>
      <div class="sms-optin-section">
        <label class="sms-checkbox-label">
          <input type="checkbox"
                 name="sms_opt_in"
                 value="1"
                 id="sms_opt_in_checkbox"
                 <%= 'checked' if @sms_opted_in %>
                 onchange="togglePhoneField(this.checked)">
          <span>Text me updates from <strong><%= @vendor_event.vendor.name %></strong> during <%= @vendor_event.event.name %></span>
        </label>

        <div id="phone_field_group" style="display:<%= @sms_opted_in ? 'block' : 'none' %>;">
          <%= f.label :phone, 'Mobile Phone', class: 'field-label' %>
          <%= f.telephone_field :phone,
                          placeholder: '(503) 555-0100',
                          class: "field-input #{'is-invalid' if @con_opt_in.errors[:phone].any?}",
                          autocomplete: 'tel',
                          inputmode: 'tel' %>
          <p class="fine-print sms-consent-text">
            By checking this box you consent to receive SMS event updates from
            <strong><%= @vendor_event.vendor.name %></strong> during
            <%= @vendor_event.event.name %>. Opt-in is voluntary and not required to
            browse this page. Message &amp; data rates may apply.
            Reply <strong>STOP</strong> to opt out at any time, <strong>HELP</strong> for help.
            <%= link_to 'Privacy Policy', 'https://crplm.com/privacy-policy',
                        target: '_blank', rel: 'noopener', style: 'color:inherit;' %>.
          </p>
        </div>
      </div>

      <div class="field-group">
        <%= f.label :email, 'Email (optional)', class: 'field-label' %>
        <%= f.email_field :email,
                          placeholder: 'you@example.com',
                          class: "field-input #{'is-invalid' if @con_opt_in.errors[:email].any?}",
                          autocomplete: 'email',
                          inputmode: 'email' %>
        <small class="fine-print" style="text-align:left; margin-top:2px;">
          For event news by email instead of text
        </small>
      </div>

      <%= f.submit 'Count Me In',
                   class: 'btn-cta',
                   data: { disable_with: 'Joining...' } %>

    <% end %>

    <p style="text-align:center; margin-top:4px;">
      <%= link_to event_feed_path(@vendor_event.event.slug), class: 'skip-link' do %>
        No thanks &mdash; just browse the event &rarr;
      <% end %>
    </p>

  </div>
</div>

<script>
  function togglePhoneField(show) {
    document.getElementById('phone_field_group').style.display = show ? 'block' : 'none';
  }
</script>
