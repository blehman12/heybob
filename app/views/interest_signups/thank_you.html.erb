<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 text-center">

      <div class="mb-4" style="font-size: 4rem;">🎉</div>
      <h1 class="mb-2">You're on the list!</h1>
      <p class="text-muted mb-4">
        Thanks for signing up. We'll reach out when new events are announced.
      </p>

      <div class="d-flex justify-content-center gap-3">
        <%= link_to "Browse Upcoming Events", public_events_path, class: "btn btn-primary" %>
        <%= link_to "Back to Home", root_path, class: "btn btn-outline-secondary" %>
      </div>

    </div>
  </div>
</div>
